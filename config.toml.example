# ─────────────────────────────────────────────────────────────────────────────
#  AISecurity Configuration
#
#  Copy to ~/.mac-security/config.toml and customize as needed.
#  All paths support ~ expansion (resolved to $HOME at runtime).
#  Every value below shows the default — omit any section to use defaults.
#
#  Override priority:  environment variable > config.toml > built-in default
# ─────────────────────────────────────────────────────────────────────────────

[general]
# PRODUCTION = all alerts + auto-quarantine
# TESTING    = alerts only, no quarantine
# DEVELOPMENT = logging only
# Env override: MACSEC_MODE
mode = "PRODUCTION"

# User-facing protection tier (switchable from menu bar):
#   relaxed  = baseline safety net, minimal interruption
#   balanced = recommended — block critical, ask about medium
#   strict   = maximum enforcement, everything monitored
# Env override: MACSEC_PROTECTION_TIER
protection_tier = "balanced"

[paths]
# Base directory for logs, quarantine, state files
# Env override: MACSEC_SECURITY_DIR
security_dir = "~/.mac-security"

# Apple Mail .emlx directory
# Env override: MACSEC_MAIL_DIR
mail_dir = "~/Library/Mail"

# iMessage / Messages database
# Env override: MACSEC_MESSAGES_DB
messages_db = "~/Library/Messages/chat.db"

# Quarantine directory for suspicious files
# Env override: MACSEC_QUARANTINE_DIR
quarantine_dir = "~/.mac-security/quarantine"

# Log directory
# Env override: MACSEC_LOG_DIR
log_dir = "~/.mac-security/logs"

[file_watcher]
enabled = true
# Directories to monitor for new/changed files
# Env override: MACSEC_SCAN_DIRS (colon-separated)
monitored_directories = ["~/Downloads", "~/Desktop", "~/Documents"]
max_scan_size_bytes = 5242880   # 5 MB
debounce_ms = 300

[email_scanner]
enabled = true
startup_scan_limit = 50

[messages_scanner]
enabled = true

[prompt_injection_guard]
enabled = true
clipboard_monitor_interval_ms = 2000

[sensitive_data_detector]
enabled = true
critical_categories = ["crypto", "financial", "credential", "pii"]

[external_file_sanitizer]
enabled = true
scan_downloads_on_start = true

[scheduled_scan]
enabled = true
interval_hours = 6
scan_directories = ["~/Downloads", "~/Desktop", "~/Documents"]

[notifications]
enabled = true
critical_only = true    # Only notify on CRITICAL in PRODUCTION

[audit]
log_blocked_operations = true
log_alerts = true
max_log_age_days = 90

[protected_paths]
# Override the default protected path list.
# Omit this section entirely to use platform defaults.
# Uncomment and customize to add/remove monitored paths:
#
# paths = [
#     "~/Pictures/Photos Library.photoslibrary",
#     "~/Pictures",
#     "~/Library/Application Support/com.apple.photoanalysisd",
#     "~/Library/Application Support/Photos",
#     "~/Library/Application Support/Sparrow",
#     "~/.sparrow",
#     "~/.bitcoin",
#     "~/.lnd",
#     "~/Library/Application Support/Bitwarden",
#     "~/Library/Application Support/Aura",
#     "~/Library/Keychains",
#     "~/Library/Mail",
#     "~/Library/Messages",
#     "~/Library/Group Containers/group.com.apple.notes",
#     "~/Library/Calendars",
#     "~/.ssh",
#     "~/.gnupg",
#     "~/Library/Safari",
#     "~/Documents/Tax Returns",
#     "~/Documents/TurboTax",
# ]

[always_forbidden]
# These are security floor controls — always active regardless of tier.
# Disabling them here is silently ignored.
wallet_key_access = true
credit_card_transmission = true
ssn_transmission = true
drivers_license_upload = true
photos_library_upload = true
keychain_dump = true
env_file_upload = true
private_pem_key_upload = true
turbotax_upload = true

# [overrides]
# Optional: override specific controls within the selected tier.
# Only set what you want to change — omitted values use tier defaults.
# Floor controls cannot be weakened (silently ignored).
#
# clipboard_monitoring_enabled = false
# clipboard_interval_ms = 10000
# email_intent_enabled = false
# email_intent_threshold = 4
# messages_scanning_enabled = false
# messages_scan_interval_ms = 120000
# scheduled_scan_enabled = false
# scheduled_scan_interval_hours = 24
# auto_quarantine = false

# ── Phase 13: AI Agent Threat Defense ────────────────────────────

[model_verification]
# Verify LLM model file integrity (SHA-256 hash on startup + real-time)
enabled = true
verify_interval_hours = 6
# Additional model directories to scan (beyond auto-discovered locations)
# paths = ["~/custom-models"]
# Paths to ignore tamper alerts for (e.g., models you actively fine-tune)
# ignore_paths = ["~/LeanInfer/models/my-finetuned-model.gguf"]

[threat_feeds]
# Real-time threat intelligence feeds (Phase 14)
# Downloads known-bad URL/domain lists, caches locally in SQLite
# All lookups are local — no user data leaves the machine
enabled = true
refresh_interval_hours = 5

[command_policy]
# Command policy engine: validate bash commands before execution
enabled = true
# Additional allowed command prefixes (beyond built-in safe list)
# allow_prefixes = ["docker", "kubectl"]
# Additional blocked patterns
# deny_patterns = ["docker run --privileged"]
# Commands that require user confirmation
# ask_prefixes = ["brew install", "pip install"]

# ── Phase 15: NemoClaw-inspired interpositional controls ────────

[privacy_router]
# Scan outbound LLM API requests for secrets / PII / credentials.
# The intercepting layer (explicit proxy, Claude-Code hook, or MITM) uses
# these decisions. See sdk/privacy-router/README.md for proxy setup.
enabled = true
# default_action: allow | warn | redact | block
default_action = "warn"
audit_enabled = true

# Per-category overrides. Categories come from sensitive_data findings:
# crypto, financial, credential, pii, api_key, app_data
[[privacy_router.categories]]
category = "credential"
action = "block"
[[privacy_router.categories]]
category = "crypto"
action = "block"
[[privacy_router.categories]]
category = "financial"
action = "block"
[[privacy_router.categories]]
category = "api_key"
action = "block"
[[privacy_router.categories]]
category = "pii"
action = "redact"
[[privacy_router.categories]]
category = "app_data"
action = "warn"

[intent_verifier]
# Pre-action gate for AI agents. An agent calls in with (task, action);
# this returns allow/deny/ask. Uses the command_policy engine plus a
# lightweight task-coherence heuristic.
enabled = true
require_task_coherence = true
default_decision = "ask"

[model_vetting]
# Vet installed models against a known-bad SHA-256 feed and a user
# allow-list. Trusted hashes short-circuit known-bad matches.
enabled = true
# Hashes the user has explicitly vouched for. Must be lowercase hex, 64 chars.
# allow_list = [
#   "3e8b...<full sha256>...",
# ]
# Optional URL to refresh known-bad-models.txt from. Leave blank for offline.
known_bad_feed_url = ""
refresh_interval_hours = 24

# ── Per-agent policy-as-code (used by ai-exec sandbox wrapper) ──
# Each [agents.<name>] defines what the named agent may read, write, and
# reach on the network. `ai-exec --agent <name> -- <cmd>` wraps the
# command in sandbox-exec with these rules.
#
# [agents.claude-code]
# allowed_paths_read  = ["~/work", "~/Documents"]
# allowed_paths_write = ["~/work"]
# allowed_network     = ["api.anthropic.com", "github.com"]
# command_policy      = "restrictive"   # default | restrictive | permissive
# description         = "Claude Code — work folders only, Anthropic/GitHub only"
#
# [agents.ollama]
# allowed_paths_read  = ["~/.ollama"]
# allowed_paths_write = ["~/.ollama"]
# allowed_network     = []              # offline-only
# command_policy      = "restrictive"
